//Step 1: Open android studio and create a new project name Calculator -> click the 3 lines present the left -> click on no activity give the name of application 
Step 2: Once the Project gets load right click on res folder -> new activity -> click on empty activity ->click on launcher activity -> project is created
Step 3 : Code for activity_main.xml(UI)
All the above are the steps how to start with the android studio project

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">
    <TextView
        android:id="@+id/txtDisplay1"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:text="0"
        android:padding="10dp"
        android:layout_marginTop="60dp"
        android:textSize="60sp"/>
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:columnCount="4"
        android:rowCount="5">
        <Button
            android:id="@+id/button7"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="7" />
        <Button
            android:id="@+id/button8"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="8" />
        <Button
            android:id="@+id/button9"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="9" />
        <Button
            android:id="@+id/buttonDiv"
            style="@style/CalcButton"
            android:onClick="onOperator"
            android:text="/" />
        <Button
            android:id="@+id/button4"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="4" />
        <Button
            android:id="@+id/button5"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="5" />
        <Button
            android:id="@+id/button6"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="6" />
        <Button
            android:id="@+id/buttonMul"
            style="@style/CalcButton"
            android:onClick="onOperator"
            android:text="*" />
        <Button
            android:id="@+id/button1"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="1" />
        <Button
            android:id="@+id/button2"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="2" />
        <Button
            android:id="@+id/button3"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="3" />
        <Button
            android:id="@+id/buttonSub"
            style="@style/CalcButton"
            android:onClick="onOperator"
            android:text="-" />
        <Button
            android:id="@+id/button0"
            style="@style/CalcButton"
            android:onClick="onDigit"
            android:text="0" />
        <Button
            android:id="@+id/buttonDot"
            style="@style/CalcButton"
            android:onClick="onDecimal"
            android:text="." />
        <Button
            android:id="@+id/buttonEq"
            style="@style/CalcButton"
            android:onClick="onEqual"
            android:text="=" />
        <Button
            android:id="@+id/buttonPlus"
            style="@style/CalcButton"
            android:onClick="onOperator"
            android:text="+" />
        <Button
            android:id="@+id/buttonClear"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="4"
            android:layout_rowWeight="1"
            android:layout_columnSpan="4"
            android:layout_margin="3dp"
            android:textSize="20dp"
            android:onClick="onClear"
            android:text="Clear" />
    </GridLayout>
</LinearLayout>
